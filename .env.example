FRONTEND_PORT=8080
BACKEND_PORT=8000
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-web-app-id
# Generate with: base64 < firebase-service-account.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_BASE64=
POSTGRES_PASSWORD=macroverse
POSTGRES_PORT=5432
# Leave blank for local Docker. Change both POSTGRES_PASSWORD and MARKET_DATABASE_URL together if customized.
# In production use the Tiger Cloud postgres:// URL with sslmode=require.
MARKET_DATABASE_URL=
MARKET_SYNC_INTERVAL_SECONDS=3600
COINMETRICS_API_BASE_URL=https://community-api.coinmetrics.io/v4
FRED_API_KEY=
CRYPTOQUANT_ACCESS_TOKEN=
# JSON array of objects with series_id, endpoint, value_key, name, unit, and window.
CRYPTOQUANT_SERIES_JSON=[]
